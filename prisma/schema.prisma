generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Registration {
  id                   String      @id @default(cuid())
  publicId             String      @unique
  name                 String
  email                String
  phone                String
  institution          String?
  type                 String
  committee1           String
  committee2           String?
  portfolio1           String?
  muns                 Int?
  awards               Int?
  experience           String?
  utr                  String?
  amount               Int         @default(1500)
  paymentProofUrl      String?
  paymentProofPublicId String?
  accommodation        String?
  transport            String?
  arrivalCity          String?
  requirements         String?
  paymentStatus        String      @default("Pending")
  registrationStatus   String      @default("Pending")
  allotmentStatus      String      @default("Not allotted")
  allottedCommittee    String?
  allottedPortfolio    String?
  checkedIn            Boolean     @default(false)
  checkedInAt          DateTime?
  checkedInBy          String?
  certificateReleased  Boolean     @default(false)
  certificateReleasedAt DateTime?
  certificateUrl       String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  notes                AdminNote[]
  paymentTransactions  PaymentTransaction[]
  certificates         Certificate[]
  awardRecords         Award[]
  whatsappLogs         WhatsAppLog[]

  @@index([email])
  @@index([phone])
  @@index([paymentStatus])
  @@index([registrationStatus])
  @@index([allotmentStatus])
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
}

model PaymentTransaction {
  id             String       @id @default(cuid())
  registrationId String
  provider       String       @default("Razorpay")
  orderId        String       @unique
  paymentId      String?
  signature      String?
  amount         Int
  currency       String       @default("INR")
  status         String       @default("Created")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([status])
}

model Certificate {
  id             String       @id @default(cuid())
  registrationId String
  title          String
  certificateNo  String       @unique
  issuedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Award {
  id             String       @id @default(cuid())
  registrationId String
  title          String
  category       String
  committee      String?
  position       String?
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([committee])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

model WhatsAppLog {
  id             String        @id @default(cuid())
  registrationId String?
  phone          String
  trigger        String
  status         String
  messageId      String?
  error          String?
  createdAt      DateTime      @default(now())
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([trigger])
  @@index([status])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  audience  String
  message   String
  createdAt DateTime @default(now())
}

model Resource {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String
  accessLevel  String
  fileUrl      String
  filePublicId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([accessLevel])
}

model EBProfile {
  id            String   @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  photoUrl      String?
  photoPublicId String?
  committee     String
  position      String
  bio           String
  instagram     String?
  linkedin      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([committee])
  @@index([position])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  institution String
  quote       String
  edition     String?
  photoUrl    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

model AdminNote {
  id             String       @id @default(cuid())
  registrationId String
  note           String
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}
