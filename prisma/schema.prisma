generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Registration {
  id                   String      @id @default(cuid())
  publicId             String      @unique
  name                 String
  email                String
  phone                String
  institution          String?
  type                 String
  committee1           String
  committee2           String?
  portfolio1           String?
  muns                 Int?
  awards               Int?
  experience           String?
  utr                  String?
  amount               Int         @default(2100)
  paymentProofUrl      String?
  paymentProofPublicId String?
  accommodation        String?
  transport            String?
  arrivalCity          String?
  requirements         String?
  paymentStatus        String      @default("Pending")
  registrationStatus   String      @default("Pending")
  allotmentStatus      String      @default("Not allotted")
  allottedCommittee    String?
  allottedPortfolio    String?
  checkedIn            Boolean     @default(false)
  checkedInAt          DateTime?
  checkedInBy          String?
  certificateReleased  Boolean     @default(false)
  certificateReleasedAt DateTime?
  certificateUrl       String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  registrationType      String      @default("individual")
  accommodationRequired Boolean     @default(false)
  paymentScreenshotUrl  String?
  paymentScreenshotPublicId String?
  totalAmountPaid       Int         @default(0)
  age                   Int?
  dob                   String?
  gender                String?
  gradeYear             String?
  portfolio2            String?
  city                  String?
  isPartOfDelegation    Boolean     @default(false)
  delegationName        String?
  refPerson             String?
  coTeacherName         String?
  coTeacherPhone        String?
  coTeacherEmail        String?
  totalDelegates        Int?
  delegateNames         String?
  notes                AdminNote[]
  paymentTransactions  PaymentTransaction[]
  certificates         Certificate[]
  awardRecords         Award[]
  whatsappLogs         WhatsAppLog[]

  @@index([email])
  @@index([phone])
  @@index([paymentStatus])
  @@index([registrationStatus])
  @@index([allotmentStatus])
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
}

model PaymentTransaction {
  id             String       @id @default(cuid())
  registrationId String
  provider       String       @default("Razorpay")
  orderId        String       @unique
  paymentId      String?
  signature      String?
  amount         Int
  currency       String       @default("INR")
  status         String       @default("Created")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([status])
}

model Certificate {
  id             String       @id @default(cuid())
  registrationId String
  title          String
  certificateNo  String       @unique
  issuedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Award {
  id             String       @id @default(cuid())
  registrationId String
  title          String
  category       String
  committee      String?
  position       String?
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([committee])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

model WhatsAppLog {
  id             String        @id @default(cuid())
  registrationId String?
  phone          String
  trigger        String
  status         String
  messageId      String?
  error          String?
  createdAt      DateTime      @default(now())
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([trigger])
  @@index([status])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  audience  String
  message   String
  createdAt DateTime @default(now())
}

model Resource {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String
  accessLevel  String
  fileUrl      String
  filePublicId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([accessLevel])
}

model EBProfile {
  id            String   @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  photoUrl      String?
  photoPublicId String?
  committee     String
  position      String
  bio           String
  instagram     String?
  linkedin      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([committee])
  @@index([position])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  institution String
  quote       String
  edition     String?
  photoUrl    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

model AdminNote {
  id             String       @id @default(cuid())
  registrationId String
  note           String
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model CheckInOtp {
  id         String   @id @default(cuid())
  delegateId String
  otpHash    String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([delegateId])
}

model IndividualRegistration {
  id                    String                         @id @default(cuid())
  publicId              String                         @unique
  trackingToken         String?                        @unique
  allotmentEmailSent    Boolean                        @default(false)
  allotmentEmailSentAt  DateTime?
  name                  String
  email                 String                         @unique
  phone                 String
  age                   Int?
  dob                   String?
  gender                String?
  institution           String?
  gradeYear             String?
  committee1            String
  portfolio1            String?
  committee2            String?
  portfolio2            String?
  city                  String?
  isPartOfDelegation    Boolean                        @default(false)
  delegationName        String?
  originalDelegationName String?
  refPerson             String?
  muns                  Int?
  awards                Int?
  experience            String?
  utr                   String?
  amount                Int                            @default(2100)
  paymentProofUrl       String?
  paymentProofPublicId  String?
  accommodation         String?
  transport             String?
  arrivalCity           String?
  requirements          String?
  paymentStatus         String                         @default("Pending")
  registrationStatus    String                         @default("Pending")
  allotmentStatus       String                         @default("Not allotted")
  allottedCommittee     String?
  allottedPortfolio     String?
  checkedIn             Boolean                        @default(false)
  checkedInAt           DateTime?
  checkedInBy           String?
  certificateReleased   Boolean                        @default(false)
  certificateReleasedAt DateTime?
  certificateUrl        String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  registrationType      String                         @default("individual")
  accommodationRequired Boolean                        @default(false)
  paymentScreenshotUrl  String?
  paymentScreenshotPublicId String?
  totalAmountPaid        Int                            @default(0)

  notes                 IndividualAdminNote[]
  paymentTransactions   IndividualPaymentTransaction[]
  certificates          IndividualCertificate[]
  awardRecords          IndividualAward[]
  whatsappLogs          IndividualWhatsAppLog[]

  @@index([email])
  @@index([phone])
  @@index([paymentStatus])
  @@index([registrationStatus])
  @@index([allotmentStatus])
}

model DelegationRegistration {
  id                    String                         @id @default(cuid())
  publicId              String                         @unique
  delegationName        String                         @unique
  institution           String?
  coTeacherName         String
  coTeacherEmail        String                         @unique
  coTeacherPhone        String
  city                  String?
  totalDelegates        Int                            @default(10)
  amount                Int                            @default(20000)
  paymentProofUrl       String?
  paymentProofPublicId  String?
  paymentStatus         String                         @default("Pending")
  registrationStatus    String                         @default("Pending")
  checkedInCount        Int                            @default(0)
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  registrationType      String                         @default("delegation")
  accommodationRequired Boolean                        @default(false)
  paymentScreenshotUrl  String?
  paymentScreenshotPublicId String?
  totalAmountPaid        Int                            @default(0)

  delegates             DelegationDelegate[]
  notes                 DelegationAdminNote[]
  paymentTransactions   DelegationPaymentTransaction[]

  @@index([coTeacherEmail])
  @@index([delegationName])
  @@index([paymentStatus])
  @@index([registrationStatus])
}

model DelegationDelegate {
  id                    String                         @id @default(cuid())
  publicId              String                         @unique
  trackingToken         String?                        @unique
  allotmentEmailSent    Boolean                        @default(false)
  allotmentEmailSentAt  DateTime?
  delegationId          String
  delegation            DelegationRegistration         @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  name                  String
  email                 String?
  phone                 String?
  originalDelegationName String?
  committee1            String?
  portfolio1            String?
  allotmentStatus       String                         @default("Not allotted")
  allottedCommittee     String?
  allottedPortfolio     String?
  checkedIn             Boolean                        @default(false)
  checkedInAt           DateTime?
  checkedInBy           String?
  certificateReleased   Boolean                        @default(false)
  certificateReleasedAt DateTime?
  certificateUrl        String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt

  notes                 DelegateAdminNote[]
  certificates          DelegateCertificate[]
  awardRecords          DelegateAward[]
  whatsappLogs          DelegateWhatsAppLog[]

  @@index([delegationId])
  @@index([email])
}

model IndividualAdminNote {
  id             String                 @id @default(cuid())
  registrationId String
  note           String
  createdAt      DateTime               @default(now())
  registration   IndividualRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model DelegationAdminNote {
  id             String                 @id @default(cuid())
  registrationId String
  note           String
  createdAt      DateTime               @default(now())
  registration   DelegationRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model DelegateAdminNote {
  id             String             @id @default(cuid())
  delegateId     String
  note           String
  createdAt      DateTime           @default(now())
  delegate       DelegationDelegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
}

model IndividualPaymentTransaction {
  id             String                 @id @default(cuid())
  registrationId String
  provider       String                 @default("Razorpay")
  orderId        String                 @unique
  paymentId      String?
  signature      String?
  amount         Int
  currency       String                 @default("INR")
  status         String                 @default("Created")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  registration   IndividualRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([status])
}

model DelegationPaymentTransaction {
  id             String                 @id @default(cuid())
  registrationId String
  provider       String                 @default("Razorpay")
  orderId        String                 @unique
  paymentId      String?
  signature      String?
  amount         Int
  currency       String                 @default("INR")
  status         String                 @default("Created")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  registration   DelegationRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([status])
}

model IndividualCertificate {
  id             String                 @id @default(cuid())
  registrationId String
  title          String
  certificateNo  String                 @unique
  issuedAt       DateTime               @default(now())
  createdAt      DateTime               @default(now())
  registration   IndividualRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model DelegateCertificate {
  id            String             @id @default(cuid())
  delegateId    String
  title         String
  certificateNo String             @unique
  issuedAt      DateTime           @default(now())
  createdAt     DateTime           @default(now())
  delegate      DelegationDelegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
}

model IndividualAward {
  id             String                 @id @default(cuid())
  registrationId String
  title          String
  category       String
  committee      String?
  position       String?
  createdAt      DateTime               @default(now())
  registration   IndividualRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([committee])
}

model DelegateAward {
  id         String             @id @default(cuid())
  delegateId String
  title      String
  category   String
  committee  String?
  position   String?
  createdAt  DateTime           @default(now())
  delegate   DelegationDelegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
  @@index([committee])
}

model IndividualWhatsAppLog {
  id             String                 @id @default(cuid())
  registrationId String?
  phone          String
  trigger        String
  status         String
  messageId      String?
  error          String?
  createdAt      DateTime               @default(now())
  registration   IndividualRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([trigger])
  @@index([status])
}

model DelegateWhatsAppLog {
  id         String              @id @default(cuid())
  delegateId String?
  phone      String
  trigger    String
  status     String
  messageId  String?
  error      String?
  createdAt  DateTime            @default(now())
  delegate   DelegationDelegate? @relation(fields: [delegateId], references: [id], onDelete: SetNull)

  @@index([delegateId])
  @@index([trigger])
  @@index([status])
}

model EmailLog {
  id          String   @id @default(cuid())
  type        String
  recipient   String
  targetType  String?
  targetId    String?
  status      String
  error       String?
  messageId   String?
  provider    String?
  createdAt   DateTime @default(now())
}

